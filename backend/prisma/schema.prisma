generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model academic_years {
  id                                                                                 Int                        @id @default(autoincrement())
  name                                                                               String                     @db.VarChar(50)
  start_date                                                                         DateTime                   @db.Date
  end_date                                                                           DateTime                   @db.Date
  is_active                                                                          Boolean                    @default(false)
  created_at                                                                         DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                                                                         DateTime?                  @db.Timestamptz(6)
  school_id                                                                          BigInt                     @unique(map: "uq_academic_years_one_active_per_school", where: raw("(is_active = true)"))
  schools                                                                            schools                    @relation(fields: [school_id], references: [id], onUpdate: NoAction, map: "fk_academic_years_school")
  attendance_sessions                                                                attendance_sessions[]
  continuing_batches_continuing_batches_from_year_idToacademic_years                 continuing_batches[]       @relation("continuing_batches_from_year_idToacademic_years")
  continuing_batches_continuing_batches_to_year_idToacademic_years                   continuing_batches[]       @relation("continuing_batches_to_year_idToacademic_years")
  exam_schedules                                                                     exam_schedules[]
  exam_timetables                                                                    exam_timetables[]
  fee_contracts_fee_contracts_academic_year_idToacademic_years                       fee_contracts[]            @relation("fee_contracts_academic_year_idToacademic_years")
  fee_contracts_fee_contracts_academic_year_id_school_idToacademic_years             fee_contracts[]            @relation("fee_contracts_academic_year_id_school_idToacademic_years")
  fee_rules                                                                          fee_rules[]
  section_advisors                                                                   section_advisors[]
  section_subject_teachers                                                           section_subject_teachers[]
  student_enrollments_student_enrollments_academic_year_idToacademic_years           student_enrollments[]      @relation("student_enrollments_academic_year_idToacademic_years")
  student_enrollments_student_enrollments_academic_year_id_school_idToacademic_years student_enrollments[]      @relation("student_enrollments_academic_year_id_school_idToacademic_years")
  student_year_results                                                               student_year_results[]
  teacher_assignments                                                                teacher_assignments[]
  teacher_attendance_days                                                            teacher_attendance_days[]
  timetables_timetables_academic_year_idToacademic_years                             timetables[]               @relation("timetables_academic_year_idToacademic_years")
  timetables_timetables_academic_year_id_school_idToacademic_years                   timetables[]               @relation("timetables_academic_year_id_school_idToacademic_years")

  @@unique([id, school_id], map: "uq_academic_years_id_school_id")
  @@unique([school_id, name], map: "uq_academic_years_school_name")
  @@index([school_id], map: "idx_academic_years_school_id")
}

model activity_logs {
  id            BigInt    @id @default(autoincrement())
  school_id     BigInt?
  user_id       Int?
  action        String?
  entity_type   String?
  entity_id     BigInt?
  description   String?
  details       Json?     @default("{}")
  metadata      Json?     @default("{}")
  path          String?
  method        String?   @db.VarChar(16)
  status_code   Int?
  ip_address    String?
  user_agent    String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  resource_type String?
  resource_id   String?

  @@index([created_at(sort: Desc)], map: "idx_activity_logs_created_at")
  @@index([school_id], map: "idx_activity_logs_school_id")
  @@index([school_id, created_at(sort: Desc)], map: "idx_activity_logs_school_id_created_at")
  @@index([user_id], map: "idx_activity_logs_user_id")
}

model assessment_attachments {
  id            BigInt      @id @default(autoincrement())
  assessment_id BigInt
  file_url      String
  file_name     String?     @db.VarChar(255)
  file_type     String?     @db.VarChar(80)
  file_size     BigInt?
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  assessments   assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ass_attach")

  @@index([assessment_id], map: "idx_ass_attach")
}

model assessment_grades {
  id                BigInt              @id @default(autoincrement())
  assessment_id     BigInt
  student_id        Int
  status            String              @default("missing") @db.VarChar(20)
  score             Decimal?            @db.Decimal(6, 2)
  feedback          String?
  graded_by         BigInt?
  graded_at         DateTime?           @db.Timestamptz(6)
  is_published      Boolean             @default(false)
  published_at      DateTime?           @db.Timestamptz(6)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  assessments       assessments         @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ag_ass")
  students          students            @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_assessment_grades_student")
  grade_change_logs grade_change_logs[]

  @@unique([assessment_id, student_id], map: "uq_assessment_grade")
  @@unique([assessment_id, student_id], map: "uq_assessment_grades_assessment_student")
  @@index([assessment_id], map: "idx_ag_assessment")
  @@index([assessment_id, is_published], map: "idx_ag_publish")
  @@index([student_id], map: "idx_ag_student")
  @@index([assessment_id], map: "idx_assessment_grades_assessment")
  @@index([student_id], map: "idx_assessment_grades_student")
}

model assessment_reopen_requests {
  id                                                           BigInt      @id @default(autoincrement())
  assessment_id                                                BigInt
  requested_by_user_id                                         Int
  reason                                                       String
  status                                                       String      @default("pending") @db.VarChar(30)
  admin_note                                                   String?
  decided_by_user_id                                           Int?
  decided_at                                                   DateTime?   @db.Timestamptz(6)
  created_at                                                   DateTime    @default(now()) @db.Timestamptz(6)
  assessments                                                  assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_assessment_reopen_requests_decided_by_user_idTousers   users?      @relation("assessment_reopen_requests_decided_by_user_idTousers", fields: [decided_by_user_id], references: [id], onUpdate: NoAction)
  users_assessment_reopen_requests_requested_by_user_idTousers users       @relation("assessment_reopen_requests_requested_by_user_idTousers", fields: [requested_by_user_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model assessments {
  id                         BigInt                       @id @default(autoincrement())
  teacher_assignment_id      BigInt
  type                       String                       @db.VarChar(30)
  mode                       String                       @db.VarChar(20)
  status                     String                       @default("draft") @db.VarChar(20)
  title                      String                       @db.VarChar(255)
  description                String?
  max_score                  Decimal                      @db.Decimal(6, 2)
  starts_at                  DateTime?                    @db.Timestamptz(6)
  due_at                     DateTime?                    @db.Timestamptz(6)
  duration_minutes           Int?
  late_policy_json           Json?
  published_at               DateTime?                    @db.Timestamptz(6)
  closed_at                  DateTime?                    @db.Timestamptz(6)
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  exam_kind                  String?                      @db.VarChar(20)
  aggregate_kind             String?                      @db.VarChar(20)
  sequence_no                Int?                         @db.SmallInt
  is_system_generated        Boolean                      @default(false)
  source_assessment_ids      Json?
  title_short                String?                      @db.VarChar(255)
  school_id                  BigInt?
  assessment_attachments     assessment_attachments[]
  assessment_grades          assessment_grades[]
  assessment_reopen_requests assessment_reopen_requests[]
  teacher_assignments        teacher_assignments          @relation(fields: [teacher_assignment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ass_ta")
  schools                    schools?                     @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assessments_school")
  submissions                submissions[]

  @@unique([teacher_assignment_id, aggregate_kind], map: "uq_assessments_aggregate_kind", where: raw("((type)::text = 'aggregate'::text)"))
  @@unique([teacher_assignment_id, exam_kind], map: "uq_assessments_midterm_final_exam", where: raw("(((type)::text = 'exam'::text) AND ((exam_kind)::text = ANY (ARRAY[('midterm'::character varying)::text, ('final'::character varying)::text])))"))
  @@unique([teacher_assignment_id, exam_kind, sequence_no], map: "uq_assessments_monthly_exam", where: raw("(((type)::text = 'exam'::text) AND ((exam_kind)::text = 'monthly'::text))"))
  @@index([starts_at, due_at], map: "idx_ass_dates")
  @@index([status], map: "idx_ass_status")
  @@index([teacher_assignment_id], map: "idx_ass_ta")
  @@index([aggregate_kind], map: "idx_assessments_aggregate_kind", where: raw("(aggregate_kind IS NOT NULL)"))
  @@index([exam_kind], map: "idx_assessments_exam_kind", where: raw("(exam_kind IS NOT NULL)"))
  @@index([teacher_assignment_id], map: "idx_assessments_teacher_assignment")
  @@index([teacher_assignment_id, exam_kind, sequence_no], map: "idx_assessments_teacher_assignment_exam_kind", where: raw("(exam_kind IS NOT NULL)"))
  @@index([teacher_assignment_id, type], map: "idx_assessments_teacher_assignment_type")
  @@index([type], map: "idx_assessments_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance_entries {
  id                  BigInt              @id @default(autoincrement())
  session_id          BigInt
  student_id          Int
  status              String
  reason_id           Int?
  late_minutes        Int?
  note                String?
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  attendance_reasons  attendance_reasons? @relation(fields: [reason_id], references: [id], onUpdate: NoAction)
  attendance_sessions attendance_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students            students            @relation(fields: [student_id], references: [id], onUpdate: NoAction)

  @@unique([session_id, student_id], map: "attendance_entries_session_student_uniq")
  @@unique([session_id, student_id], map: "uniq_attendance_entry")
  @@unique([session_id, student_id], map: "uniq_attendance_entry_once")
  @@unique([session_id, student_id], map: "ux_att_entries_session_student")
  @@unique([session_id, student_id], map: "ux_attendance_entries_session_student")
  @@index([session_id], map: "attendance_entries_session_idx")
  @@index([session_id], map: "idx_attendance_entries_session")
  @@index([session_id], map: "idx_entries_session")
  @@index([status], map: "ix_att_entries_status")
  @@index([student_id], map: "ix_att_entries_student")
  @@index([student_id, session_id], map: "ix_att_entries_student_session")
}

model attendance_entry_corrections {
  id                     BigInt               @id @default(autoincrement())
  session_id             BigInt
  student_id             Int
  corrected_status       String               @db.VarChar(20)
  corrected_reason_id    Int?
  corrected_late_minutes Int?
  corrected_note         String?
  correction_reason      String
  corrected_by_user_id   Int?
  created_at             DateTime             @default(now()) @db.Timestamptz(6)
  permission_request_id  BigInt?
  permission_requests    permission_requests? @relation(fields: [permission_request_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attendance_sessions    attendance_sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students               students             @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attendance_reasons     attendance_reasons?  @relation(fields: [corrected_reason_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_att_corr_reason")
  users                  users?               @relation(fields: [corrected_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_att_corr_user")

  @@index([session_id, student_id, created_at(sort: Desc)], map: "idx_aec_session_student")
  @@index([session_id, student_id, created_at(sort: Desc)], map: "idx_att_corr_session_student_created")
}

model attendance_reasons {
  id                           Int                            @id @default(autoincrement())
  name                         String
  is_active                    Boolean                        @default(true)
  created_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  school_id                    BigInt?
  attendance_entries           attendance_entries[]
  attendance_entry_corrections attendance_entry_corrections[]
  schools                      schools?                       @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_attendance_reasons_school")

  @@unique([school_id, name], map: "uq_attendance_reasons_school_name")
}

