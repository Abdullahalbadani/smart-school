model employees {
  id         BigInt    @id @default(autoincrement())
  user_id    Int?      @unique
  teacher_id Int?      @unique
  full_name  String
  phone      String
  job_title  String?
  notes      String?
  is_teacher Boolean   @default(false)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  school_id  BigInt
  schools    schools   @relation(fields: [school_id], references: [id], onUpdate: NoAction, map: "fk_employees_school")
  teachers   teachers? @relation(fields: [teacher_id], references: [id], onUpdate: NoAction, map: "fk_employees_teacher")
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_employees_user")

  @@index([is_active], map: "idx_employees_active")
  @@index([is_teacher], map: "idx_employees_is_teacher")
  @@index([school_id, is_active], map: "idx_employees_school_active")
  @@index([school_id], map: "idx_employees_school_id")
  @@index([school_id, teacher_id], map: "idx_employees_school_teacher_id")
  @@index([school_id, user_id], map: "idx_employees_school_user_id")
  @@index([full_name, phone], map: "idx_employees_search")
}

model exam_entries {
  id                    Int            @id @default(autoincrement())
  exam_schedule_id      Int
