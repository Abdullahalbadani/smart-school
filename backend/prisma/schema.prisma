  subjects              subjects       @relation(fields: [subject_id], references: [id], onUpdate: NoAction)
  teachers              teachers?      @relation(fields: [supervisor_teacher_id], references: [id], onUpdate: NoAction)

  @@index([exam_date], map: "idx_exam_entries_date")
  @@index([exam_schedule_id], map: "idx_exam_entries_schedule")
}

